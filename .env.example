# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# M-Pesa Configuration (Daraja API)
VITE_MPESA_CONSUMER_KEY=your-consumer-key-here
VITE_MPESA_CONSUMER_SECRET=your-consumer-secret-here
VITE_MPESA_SHORTCODE=your-shortcode-here
VITE_MPESA_PASSKEY=your-passkey-here
VITE_MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa-webhook

# SMS Configuration (TextSMS Kenya)
VITE_SMS_API_KEY=your-sms-api-key-here
VITE_SMS_PARTNER_ID=your-partner-id-here
VITE_SMS_SHORTCODE=WELFARE

# Rate Limiting & Security
VITE_REDIS_URL=https://your-redis-server:port
VITE_REDIS_TOKEN=your-redis-token-here

# Application URLs
VITE_APP_URL=https://your-domain.com
VITE_ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# Email Configuration (for password resets)
VITE_EMAIL_SERVICE=sendgrid
VITE_SENDGRID_API_KEY=your-sendgrid-key-here
VITE_SENDER_EMAIL=noreply@your-domain.com

# Environment
VITE_ENV=production
